      "parameters": {
        "jsCode": "function flattenNames(arr) {\n  return arr?.map(x => typeof x === 'string' ? x : x.name).filter(Boolean) || [];\n}\n\nreturn items.map(item => {\n  const g = { ...item.json };\n\n  // Flatten genres from {id, name} objects to name strings\n  g.genres = flattenNames(g.genres);\n\n  // Extract Denmark watch providers (flatrate/rent/buy)\n  const dk = g['watch/providers']?.results?.DK || {};\n  g.providers = [\n    ...(dk.flatrate || []).map(p => ({ ...p, type: 'flatrate' })),\n    ...(dk.rent     || []).map(p => ({ ...p, type: 'rent'     })),\n    ...(dk.buy      || []).map(p => ({ ...p, type: 'buy'      })),\n  ].map(p => ({\n    provider_id:   p.provider_id,\n    provider_name: p.provider_name,\n    logo_path:     p.logo_path,\n    type:          p.type,\n    country:       'DK',\n  }));\n  delete g['watch/providers'];\n\n  // Extract top 5 cast members (TMDB sorts cast by billing order)\n  const cast = g.credits?.cast || [];\n  g.actors = cast.slice(0, 5).map(c => c.name).filter(Boolean);\n  delete g.credits;\n\n  // Build embedding text for semantic search\n  g.embedding_text = [\n    `Title: ${g.title || ''}`,\n    `Status: ${g.status || ''}`,\n    `Genres: ${g.genres.join(', ')}`,\n    `Language: ${g.original_language || ''}`,\n    `Release: ${g.release_date || ''}`,\n    `Runtime: ${g.runtime || ''} min`,\n    `Overview: ${g.overview || ''}`\n  ].join(' ')\n    .replace(/\\n+/g, ' ')\n    .replace(/\\\\/g, '\\\\\\\\')\n    .replace(/\"/g, '\\\\\"')\n    .trim();\n\n  // Keep original for merge step\n  g.original = { ...g };\n\n  // Remove null/empty fields\n  for (const key of Object.keys(g)) {\n    const v = g[key];\n    if (v === null || v === undefined || v === '' ||\n        (Array.isArray(v) && v.length === 0)) {\n      delete g[key];\n    }\n  }\n\n  return { json: g };\n});"
      },
