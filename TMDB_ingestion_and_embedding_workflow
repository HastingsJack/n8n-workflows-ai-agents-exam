    {
      "parameters": {
        "jsCode": "const originalMovies = $items('Movie Metadata Formatter');\nconst embeddings = items;\n\nconst movies = embeddings.map((embItem, i) => {\n  const orig = originalMovies[i]?.json?.original || originalMovies[i]?.json || {};\n  return {\n    id:                orig.id,\n    title:             orig.title             || '',\n    status:            orig.status            || '',\n    overview:          orig.overview          || '',\n    release_date:      orig.release_date      || '',\n    runtime:           orig.runtime           || 0,\n    original_language: orig.original_language || '',\n    vote_average:      orig.vote_average      || 0,\n    genres:            (orig.genres || []).map(x => String(x).trim()),\n    providers:         orig.providers || [],\n    actors:            orig.actors || [],\n    embedding:         embItem.json.embedding || []\n  };\n}).filter(m => m.id);\n\nconst statement = `\nUNWIND $movies AS movie\nMERGE (m:Movie {tmdb_id: movie.id})\nSET m.title             = movie.title,\n    m.status            = movie.status,\n    m.overview          = movie.overview,\n    m.release_date      = movie.release_date,\n    m.runtime           = movie.runtime,\n    m.original_language = movie.original_language,\n    m.vote_average      = movie.vote_average,\n    m.actors            = movie.actors,\n    m.embedding         = movie.embedding\nFOREACH (genreName IN CASE WHEN movie.genres IS NULL THEN [] ELSE movie.genres END |\n  MERGE (g:Genre {name: genreName})\n  MERGE (m)-[:IN_GENRE]->(g)\n)\nFOREACH (prov IN CASE WHEN movie.providers IS NULL THEN [] ELSE movie.providers END |\n  MERGE (p:Provider {tmdb_id: prov.provider_id})\n  SET p.name = prov.provider_name,\n      p.logo_path = prov.logo_path\n  MERGE (m)-[:AVAILABLE_ON {type: prov.type, country: prov.country}]->(p)\n)\n`;\n\nreturn [{\n  json: {\n    payload: {\n      statements: [{ statement, parameters: { movies } }]\n    }\n  }\n}];"
      },
