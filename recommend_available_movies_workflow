        "jsCode": "// If Build Cypher short-circuited (no active subs), return the error early\nconst upstream = $('Build Cypher').first().json;\nif (upstream && upstream.error) {\n  return [{ json: { ok: false, error: upstream.error, message: upstream.message, recommendations: [] } }];\n}\n\nconst resp = items[0]?.json;\n\n// Surface Neo4j errors instead of silently returning empty\nif (resp?.errors && resp.errors.length > 0) {\n  return [{\n    json: {\n      ok: false,\n      error: 'neo4j_error',\n      neo4j_errors: resp.errors,\n      recommendations: []\n    }\n  }];\n}\n\nconst r = resp?.results?.[0];\nif (!r || !r.data?.length) {\n  return [{\n    json: {\n      ok: true,\n      recommendations: [],\n      message: 'No recommendations matched the active subscriptions. Check that movie ingest ran and that provider names align.'\n    }\n  }];\n}\nconst cols = r.columns;\nconst recs = r.data.map(row => Object.fromEntries(cols.map((c, i) => [c, row.row[i]])));\nreturn [{ json: { ok: true, recommendations: recs } }];"
