      "parameters": {
        "jsCode": "// Active subscriptions come from the Airtable node's output (items here)\nconst activeProviders = items\n  .map(it => it.json.fields ?? it.json)\n  .filter(f => f.Active === true && f.Provider)\n  .map(f => f.Provider);\n\n// Webhook body is upstream of the Airtable node \u2014 access it via $('Webhook')\nconst webhookJson = $('Webhook').first().json ?? {};\nconst body = webhookJson.body ?? webhookJson ?? {};\nconst limit = Number(body.limit) || 5;\n\nif (activeProviders.length === 0) {\n  return [{\n    json: {\n      payload: null,\n      error: 'no_active_subscriptions',\n      message: 'No subscriptions marked Active=true in Airtable.'\n    }\n  }];\n}\n\nconst statement = `\nMERGE (u:User {name: 'USER_NAME'})\nWITH u\nOPTIONAL MATCH (u)-[r:WATCHED]->(liked:Movie)\nWHERE r.liked = true AND liked.embedding IS NOT NULL\nWITH u, collect(liked.embedding) AS liked_embeddings\nWITH u, liked_embeddings,\n  CASE WHEN size(liked_embeddings) > 0 THEN\n    [i IN range(0, size(liked_embeddings[0])-1) |\n       reduce(s = 0.0, e IN liked_embeddings | s + e[i]) / toFloat(size(liked_embeddings))\n    ]\n  ELSE null\n  END AS taste_vector\nMATCH (m:Movie)-[:AVAILABLE_ON {type: 'flatrate', country: 'DK'}]->(p:Provider)\nWHERE any(sub IN $active_providers WHERE\n        toLower(p.name) = toLower(sub)\n        OR toLower(p.name) CONTAINS toLower(sub))\n  AND NOT EXISTS { (u)-[:WATCHED]->(m) }\n  AND m.embedding IS NOT NULL\n  AND size(m.embedding) > 0\nWITH m, taste_vector, collect(DISTINCT p.name) AS providers\nWITH m, providers, taste_vector,\n  CASE\n    WHEN taste_vector IS NULL THEN coalesce(m.vote_average, 0) / 10.0\n    ELSE\n      reduce(dot = 0.0, i IN range(0, size(taste_vector)-1) | dot + taste_vector[i] * m.embedding[i])\n      /\n      (\n        sqrt(reduce(s = 0.0, v IN taste_vector | s + v*v)) *\n        sqrt(reduce(s = 0.0, v IN m.embedding   | s + v*v))\n      )\n  END AS score\nORDER BY score DESC\nLIMIT $limit\nRETURN m.title         AS title,\n       m.overview      AS summary,\n       m.vote_average  AS tmdb_rating,\n       m.runtime       AS runtime,\n       m.actors        AS actors,\n       score,\n       providers,\n       taste_vector IS NOT NULL AS personalized\n`;\n\nreturn [{\n  json: {\n    payload: {\n      statements: [{\n        statement,\n        parameters: {\n          active_providers: activeProviders,\n          limit\n        }\n      }]\n    },\n    debug: { active_providers: activeProviders, limit }\n  }\n}];"
      },
